{
  "name": "my-app",
  "version": "1.0.0",
  "private": true,
  "description": "CloudBase full-stack monorepo with React + TypeScript",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "npm run dev --workspace Template",
    "build": "npm run build --workspace Template && npm run build --workspace api-function",
    "lint": "npm run lint --workspace Template",
    "deploy:function": "npm run deploy --workspace api-function",
    "deploy:web": "npm run deploy --workspace Template"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
